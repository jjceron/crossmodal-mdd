cache/

# Generated outputs (experiment results, figures)
outputs/

# Temporary files
tmp/ 

# Documentation: only *.md at root level; exclude tex/ subfolder
docs/

# Archives (large data transfer files)
*.tar.gz
*.tar

# OS artifacts
.DS_Store
Thumbs.db 
desktop.ini

# IDE / editor 
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Skills / agent instructions (local only, not shared)
skills/

# ignore logs/
logs/